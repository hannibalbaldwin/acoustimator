# Neon PostgreSQL (pooled endpoint for app)
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.us-east-2.aws.neon.tech/acoustimator?sslmode=require

# Neon PostgreSQL (direct endpoint for migrations)
DATABASE_URL_DIRECT=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/acoustimator?sslmode=require

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxx

# Source data path
DATA_SOURCE_PATH=/path/to/Dropbox/+ITBs
